# ── Primary Twitter data source ──
# Sign up at https://socialdata.tools — $0.0002 per profile/tweet, free credits on signup
SOCIALDATA_API_KEY=your_socialdata_api_key_here

# ── AI analysis ──
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional fallbacks ──
# twitterapi.io — used as Layer 2 if SOCIALDATA_API_KEY runs out
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here

# Kimi fallback AI
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
